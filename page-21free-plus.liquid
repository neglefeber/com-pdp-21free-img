{% comment %} v38 {% endcomment %}
<style>
  :root {
    --mahogany: #601119;
    --charcoal: #2D2D2D;
    --arctic: #FCFBFB;
    --porcelain: #F8F7F6;
    --linen: #F1EFED;
    --fog: #E7E5E3;
    --green: #10682f;
    --green-tint: #10682f1a;
    --font-body: 'Nimbus Sans Novus', system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
    --font-display: 'Nimbus Sans Novus Cond', 'Helvetica Neue Condensed', 'Arial Narrow', sans-serif;
    --radius: 2px;
    --page-pad: 80px;
    --max: 1600px;
  }

  *, *::before, *::after { box-sizing: border-box; letter-spacing: 0; }
  html, body { overflow-x: hidden; }
  body {
    margin: 0;
    font-family: var(--font-body);
    color: var(--charcoal);
    background: var(--arctic);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  img, svg { max-width: 100%; height: auto; }
  a { color: inherit; }

  .container {
    max-width: var(--max);
    margin: 0 auto;
    padding-left: var(--page-pad);
    padding-right: var(--page-pad);
  }

  /* TYPOGRAPHY */
  .h-display {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
    letter-spacing: 0;
    margin: 0;
    color: var(--charcoal);
  }
  .eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--charcoal);
    margin: 0 0 16px;
  }

  /* PRIMARY BUTTON (mahogany, matches PDP CTA) */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--mahogany);
    color: var(--arctic);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    line-height: 1;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0 28px;
    height: 50px;
    border-radius: var(--radius);
    transition: opacity .2s ease;
    border: none;
    cursor: pointer;
  }
  .btn:hover { opacity: 0.9; color: var(--arctic); }
  .btn--outline {
    background: transparent;
    color: var(--charcoal);
    border: 1px solid var(--charcoal);
  }
  .btn--outline:hover { background: var(--charcoal); color: var(--arctic); }

  /* ===== HERO (matches PDP 21FREE pattern: arctic card on porcelain bg) ===== */
  .hero {
    background: var(--porcelain);
    padding: 48px 0 64px;
  }
  .hero__card {
    background: var(--arctic);
    border: 1px solid var(--fog);
    border-radius: var(--radius);
    overflow: hidden;
    display: grid;
    grid-template-columns: 47% 1fr;
    align-items: stretch;
    min-height: 480px;
  }
  .hero__content {
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero__badge-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 36px;
  }
  .hero__badge {
    display: inline-flex;
    align-items: center;
    background: var(--green-tint);
    color: var(--charcoal);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 13px;
    line-height: 1;
    padding: 8px 12px;
    border-radius: var(--radius);
  }
  .hero__hashtag {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 15px;
    line-height: 1;
    color: var(--charcoal);
    text-decoration: none;
    border-bottom: 2px solid var(--charcoal);
    padding-bottom: 2px;
  }
  .hero__title {
    font-size: clamp(44px, 5.4vw, 88px);
    line-height: 0.92;
    margin: 0 0 28px;
  }
  .hero__lede {
    font-size: 18px;
    line-height: 1.55;
    color: var(--charcoal);
    margin: 0;
    max-width: 460px;
  }
  .hero__note {
    font-size: 14px;
    line-height: 1.6;
    color: var(--charcoal);
    opacity: 0.75;
    margin: 28px 0 0;
    padding-top: 24px;
    border-top: 1px solid var(--fog);
    max-width: 460px;
  }
  .hero__note-link {
    color: var(--mahogany);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    white-space: nowrap;
    opacity: 1;
  }
  .hero__note-link:hover { opacity: 0.75; }
  .hero__cta-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero__media {
    position: relative;
    overflow: hidden;
    min-height: 480px;
    background: var(--arctic);
  }
  .hero__drop {
    position: absolute;
    width: 110%;
    height: auto;
    top: -8%;
    left: -2%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  /* ===== INLINE TRUST STRIP (subtle, no dark bg) ===== */
  .trust-strip {
    background: var(--arctic);
    border-top: 1px solid var(--fog);
    border-bottom: 1px solid var(--fog);
    padding: 24px 0;
  }
  .trust-strip__row {
    display: flex;
    gap: 56px;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }
  .trust-strip__item {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--charcoal);
    opacity: 0.85;
  }
  .trust-strip__dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--mahogany);
    opacity: 0.4;
  }

  /* ===== SECTION DEFAULTS ===== */
  section { padding: 88px 0; }
  .section__head {
    max-width: 760px;
    margin: 0 0 48px;
  }
  .section__head--center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }
  .section__title {
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1;
    margin: 0 0 20px;
  }
  .section__lede {
    font-size: 17px;
    line-height: 1.55;
    color: var(--charcoal);
    opacity: 0.85;
    margin: 0;
    max-width: 560px;
  }
  .section__head--center .section__lede { margin: 0 auto; }

  /* ===== MANIFESTO ===== */
  .manifesto {
    background: var(--arctic);
  }
  .manifesto__grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 80px;
    align-items: center;
  }
  .manifesto__title {
    font-size: clamp(40px, 4.8vw, 64px);
    line-height: 1;
    margin: 0 0 28px;
  }
  .manifesto__body p {
    font-size: 17px;
    line-height: 1.65;
    margin: 0 0 16px;
    color: var(--charcoal);
  }
  .manifesto__media {
    position: relative;
    aspect-ratio: 4/5;
    background: var(--arctic);
    border: 1px solid var(--fog);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .manifesto__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ===== AWARDS (3 team photos with judge quotes) ===== */
  .awards {
    background: var(--linen);
  }
  .awards__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .award-card {
    background: var(--porcelain);
    border: 1px solid var(--fog);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .award-card__media {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--linen);
  }
  .award-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .award-card__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--mahogany);
    color: var(--arctic);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 7px 12px;
    border-radius: var(--radius);
    line-height: 1;
  }
  .award-card__body {
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .award-card__source {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--mahogany);
    margin: 0 0 8px;
  }
  .award-card__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--charcoal);
    margin: 0 0 20px;
  }
  .award-card__quote {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    line-height: 1.55;
    color: var(--charcoal);
    opacity: 0.85;
    margin: 0 0 16px;
    padding: 0;
    border: 0;
    quotes: """ """;
    flex: 1;
    font-style: normal;
  }
  .award-card__quote::before {
    content: open-quote;
  }
  .award-card__quote::after {
    content: close-quote;
  }
  .award-card__attr {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    color: var(--charcoal);
    opacity: 0.65;
    letter-spacing: 0.3px;
    margin: 0;
    line-height: 1.5;
  }
  .award-card__attr a {
    color: var(--mahogany);
    text-decoration: none;
    border-bottom: 1px solid var(--mahogany);
    padding-bottom: 1px;
  }
  .award-card__attr a:hover { opacity: 0.7; }
  .awards__press {
    margin: 72px 0 0;
    padding-top: 48px;
    border-top: 1px solid var(--fog);
  }
  .awards__press-label {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    color: var(--charcoal);
    opacity: 0.55;
    text-align: center;
    margin: 0 0 32px;
  }
  .press-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    align-items: center;
    justify-items: center;
  }
  .press-strip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-decoration: none;
    color: var(--charcoal);
    transition: opacity .2s ease;
    padding: 12px 8px;
    width: 100%;
    text-align: center;
  }
  .press-strip__item:hover { opacity: 0.7; }
  .press-strip__visual {
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .press-strip__visual img {
    max-height: 64px;
    width: auto;
    display: block;
  }
  .press-strip__caption {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--charcoal);
    opacity: 0.65;
    line-height: 1.4;
  }
  .press-strip__caption strong {
    display: block;
    font-weight: 700;
    color: var(--mahogany);
    opacity: 1;
    font-size: 12px;
    margin-bottom: 2px;
    letter-spacing: 1.6px;
  }
  .press-strip__visual {
    height: 140px;
  }
  .press-strip__visual--logo img {
    max-height: 64px;
    max-width: 100%;
    object-fit: contain;
  }
  .press-strip__visual--medal img {
    max-height: 140px;
  }
  /* E-handelsprisen badge has a dangling gold sub-tag — needs more space so main circle matches DBA */
  .press-strip__visual--medal-ehandel img {
    max-height: 160px;
  }
  /* Costume wordmark — sized to match other logos visually */
  .press-strip__visual--logo-costume img {
    max-height: 24px;
    max-width: 180px;
  }

  /* ===== THE 21 (chip-tag list, matches PDP design) ===== */
  .list-21 { background: var(--porcelain); }
  .list-21__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 14px;
    margin-bottom: 80px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--arctic);
    border: 1px solid var(--fog);
    border-radius: 32px;
    padding: 14px 22px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 16px;
    line-height: 1;
    color: var(--charcoal);
    transition: border-color .2s ease;
  }
  .chip:hover { border-color: var(--mahogany); }
  .chip svg { width: 12px; height: 12px; flex-shrink: 0; }

  .list-21__sub {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--charcoal);
    opacity: 0.7;
    max-width: 720px;
    margin: 0 0 32px;
  }
  .list-21__sub strong { font-weight: 700; opacity: 1; }

  /* Accordion */
  .accordion { border-top: 1px solid var(--fog); }
  .accordion__item {
    border-bottom: 1px solid var(--fog);
  }
  .accordion__summary {
    display: grid;
    grid-template-columns: 80px 1fr 32px;
    gap: 24px;
    align-items: center;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    transition: opacity .2s ease;
  }
  .accordion__summary::-webkit-details-marker { display: none; }
  .accordion__summary:hover { opacity: 0.7; }
  .accordion__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    color: var(--mahogany);
    letter-spacing: 0.5px;
  }
  .accordion__num--plus {
    font-size: 26px;
    line-height: 1;
  }
  .accordion__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    text-transform: uppercase;
    color: var(--charcoal);
    line-height: 1;
  }
  .accordion__icon {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 28px;
    color: var(--charcoal);
    line-height: 1;
    text-align: center;
    transition: transform .2s ease;
    user-select: none;
  }
  .accordion__item[open] .accordion__icon {
    transform: rotate(45deg);
    color: var(--mahogany);
  }
  .accordion__body {
    padding: 0 32px 28px 104px;
  }
  .accordion__body p {
    font-size: 15px;
    line-height: 1.6;
    color: var(--charcoal);
    opacity: 0.85;
    margin: 0;
    max-width: 720px;
  }
  .accordion__body p + p {
    margin-top: 12px;
  }

  /* ===== EDITORIAL COMPARE (light, two columns side by side) ===== */
  .compare {
    background: var(--porcelain);
  }
  .compare__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .compare__col {
    background: var(--arctic);
    border: 1px solid var(--fog);
    border-radius: var(--radius);
    padding: 48px 40px;
  }
  .compare__col--us {
    border-color: var(--charcoal);
  }
  .compare__col-eyebrow {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--charcoal);
    opacity: 0.55;
    margin: 0 0 12px;
  }
  .compare__col--us .compare__col-eyebrow {
    color: var(--mahogany);
    opacity: 1;
  }
  .compare__col-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    line-height: 1;
    text-transform: uppercase;
    color: var(--charcoal);
    margin: 0 0 24px;
  }
  .compare__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .compare__list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--fog);
    font-size: 15px;
    line-height: 1.4;
    color: var(--charcoal);
  }
  .compare__list li:last-child { border-bottom: 0; }
  .compare__list-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 1px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  /* ===== TRUST (clean text-driven, no icon boxes) ===== */
  .trust {
    background: var(--arctic);
  }
  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .trust__item {
    padding-top: 24px;
    border-top: 1px solid var(--fog);
  }
  .trust__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--mahogany);
    letter-spacing: 1.4px;
    margin: 0 0 12px;
    text-transform: uppercase;
  }
  .trust__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--charcoal);
    margin: 0 0 12px;
  }
  .trust__text {
    font-size: 14px;
    line-height: 1.55;
    color: var(--charcoal);
    opacity: 0.75;
    margin: 0;
  }

  /* ===== TESTIMONIAL (Trustpilot block + customer quote) ===== */
  .testimonial {
    background: var(--linen);
    text-align: center;
  }
  .testimonial__trustpilot {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    color: inherit;
    transition: opacity .2s ease;
  }
  .testimonial__trustpilot:hover { opacity: 0.85; }
  .testimonial__tp-link {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--mahogany);
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-top: 8px;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .testimonial__tp-logo {
    width: 140px;
    height: auto;
    color: var(--charcoal);
  }
  .testimonial__tp-rating {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .testimonial__tp-stars {
    display: inline-flex;
    gap: 3px;
  }
  .tp-star {
    width: 24px;
    height: 24px;
    background: #00B67A;
    clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  }
  .testimonial__tp-score {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.5px;
    color: var(--charcoal);
  }
  .testimonial__tp-count {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 14px;
    color: var(--charcoal);
    opacity: 0.65;
    margin: 0;
  }
  .testimonial__tp-count strong {
    font-weight: 700;
    color: var(--charcoal);
    opacity: 1;
  }
  .testimonial__stars {
    color: var(--mahogany);
    font-size: 16px;
    letter-spacing: 4px;
    margin-bottom: 24px;
  }
  .testimonial__quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 3.4vw, 48px);
    line-height: 1.1;
    text-transform: uppercase;
    color: var(--charcoal);
    max-width: 1000px;
    margin: 0 auto 24px;
  }
  .testimonial__author {
    font-size: 14px;
    color: var(--charcoal);
    opacity: 0.65;
    letter-spacing: 0.5px;
  }
  .testimonial__quote-block {
    max-width: 720px;
    margin: 64px auto 0;
    padding: 48px 0 0;
    border: 0;
    border-top: 1px solid var(--fog);
    font-style: normal;
  }
  .testimonial__quote-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.25;
    color: var(--charcoal);
    margin: 0 0 24px;
    letter-spacing: -0.2px;
    font-style: normal;
  }
  .testimonial__quote-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--charcoal);
    opacity: 0.7;
    font-style: normal;
  }
  .tp-mini-stars {
    display: inline-flex;
    gap: 2px;
  }
  .tp-mini-stars .tp-star {
    width: 14px;
    height: 14px;
  }

  /* ===== PRESS STRIP SECTION (standalone, just before final CTA) ===== */
  .press {
    background: var(--linen);
  }
  .press .awards__press-label {
    margin-bottom: 40px;
  }

  /* ===== FINAL CTA (light editorial like PDP 21FREE inverse) ===== */
  .final {
    background: var(--arctic);
    text-align: center;
  }
  .final__title {
    font-size: clamp(48px, 6vw, 88px);
    line-height: 0.95;
    margin: 0 0 24px;
  }
  .final__lede {
    max-width: 560px;
    margin: 0 auto 36px;
    font-size: 17px;
    line-height: 1.55;
    color: var(--charcoal);
    opacity: 0.85;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 990px) {
    :root { --page-pad: 32px; }
    .hero { padding: 32px 0 48px; }
    .hero__card {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero__content { padding: 48px 32px; }
