  <!-- THE 21 -->
  <section class="list-21">
    <div class="container">
      <div class="section__head">
        <p class="eyebrow">De 21 vi har fjernet</p>
        <h2 class="h-display section__title">Hva vi sier nei til</h2>
        <p class="section__lede">Hver ingrediens på listen er enten regulert av EU, dokumentert allergifremkallende eller på vei vekk fra markedet. Vi var bare litt raskere enn lovgivningen.</p>
      </div>

      <div class="list-21__tags">
        <span class="chip"><span class="chip__x">×</span>Parfyme</span>
        <span class="chip"><span class="chip__x">×</span>Parabener</span>
        <span class="chip"><span class="chip__x">×</span>PFAS</span>
