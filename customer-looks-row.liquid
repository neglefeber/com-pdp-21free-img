{%- comment -%}
  THE LOOKS — horizontal scrollable row variant of customer-looks-grid.

  v2 (2026-05-22): On PDP, filter customer_photos to only those tagged with
  current product. Stock rule: if host product is in stock, hide looks where
  any other tagged product is sold out. If host is sold out, show all.
  Falls back to legacy "first N" mode when not on a PDP.
{%- endcomment -%}

{%- liquid
  assign sec_id = 'cl-row-' | append: section.id
  assign cta_url = section.settings.cta_link | default: '/pages/customer-looks'
  assign cta_label = section.settings.cta_text | default: 'Se alle looks'
  assign limit = section.settings.count | default: 12
  assign host_product = product
  assign max_scan = 500
-%}

<section class="cl-row-section" id="{{ sec_id }}" data-cl-row>
  <div class="cl-row-container">
    <div class="cl-row-head">
      <div class="cl-row-head__text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="cl-row-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="cl-row-title">{{ section.settings.heading | default: 'THE LOOKS' }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="cl-row-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if cta_label != blank -%}
        <a class="cl-row-cta" href="{{ cta_url }}">{{ cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="cl-row-scroll" tabindex="0" aria-label="{{ section.settings.heading }}">
      <ul class="cl-row-track">
        {%- assign cnt = 0 -%}
        {%- for cp in shop.metaobjects.customer_photo.values limit: max_scan -%}
          {%- if cnt >= limit -%}{%- break -%}{%- endif -%}
          {%- assign img = cp.image_file.value -%}
          {%- assign tagged = cp.tagged_products.value -%}
          {%- if img == blank -%}{%- continue -%}{%- endif -%}

          {%- comment -%} PDP filter: card must include host_product, with stock rule {%- endcomment -%}
          {%- if host_product != blank -%}
            {%- assign has_host = false -%}
            {%- assign host_sold_out = false -%}
            {%- for tp in tagged -%}
              {%- if tp.id == host_product.id -%}
                {%- assign has_host = true -%}
                {%- unless tp.selected_or_first_available_variant.available -%}
                  {%- assign host_sold_out = true -%}
                {%- endunless -%}
              {%- endif -%}
            {%- endfor -%}
            {%- unless has_host -%}{%- continue -%}{%- endunless -%}

            {%- comment -%} If host in stock, require all other products in stock too {%- endcomment -%}
            {%- unless host_sold_out -%}
              {%- assign other_sold_out = false -%}
              {%- for tp in tagged -%}
                {%- unless tp.id == host_product.id -%}
                  {%- unless tp.selected_or_first_available_variant.available -%}
                    {%- assign other_sold_out = true -%}
                    {%- break -%}
                  {%- endunless -%}
                {%- endunless -%}
              {%- endfor -%}
              {%- if other_sold_out -%}{%- continue -%}{%- endif -%}
            {%- endunless -%}
          {%- endif -%}

          {%- assign cnt = cnt | plus: 1 -%}

          <li class="cl-row-card" data-cl-card>
            <div class="cl-row-card__image-wrap">
              {{
                img
                | image_url: width: 600
                | image_tag:
                    loading: 'lazy',
                    widths: '290,400,580',
                    sizes: '290px',
                    class: 'cl-row-card__image',
                    alt: cp.caption.value
              }}
            </div>

            {%- if tagged.size > 0 -%}
              <ul class="cl-row-card__chips">
                {%- for tp in tagged -%}
                  {%- assign variant = tp.selected_or_first_available_variant -%}
                  {%- assign sold_out = false -%}{%- unless variant.available -%}{%- assign sold_out = true -%}{%- endunless -%}
                  {%- assign title_parts = tp.title | split: ' • ' -%}
                  {%- if title_parts.size >= 2 -%}
                    {%- assign chip_label = title_parts[1] -%}
                  {%- else -%}
                    {%- assign chip_label = tp.title -%}
                  {%- endif -%}

                  <li>
                    <label class="cl-chip{% if sold_out %} cl-chip--sold-out{% endif %}">
                      <input type="checkbox" class="cl-chip__input" data-variant-id="{{ variant.id }}" data-product-handle="{{ tp.handle }}"{% if sold_out %} disabled{% endif %} />
                      <a class="cl-chip__thumb" href="{{ tp.url }}" tabindex="-1" aria-label="{{ tp.title | escape }}">
                        {%- if tp.featured_image -%}
                          {{
                            tp.featured_image
                            | image_url: width: 140
                            | image_tag:
                                loading: 'lazy',
                                widths: '70,140',
                                sizes: '47px',
                                alt: tp.title
                          }}
                        {%- endif -%}
                      </a>
                      <div class="cl-chip__body">
                        <span class="cl-chip__title">{{ chip_label }}</span>
                        <span class="cl-chip__price">
                          {%- if variant.compare_at_price > variant.price -%}
                            <span class="cl-chip__price-now">{{ variant.price | money }}</span>
                            <span class="cl-chip__price-was">{{ variant.compare_at_price | money }}</span>
                          {%- else -%}
                            {{ variant.price | money }}
                          {%- endif -%}
                        </span>
                      </div>
                      <span class="cl-chip__checkbox" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="3.5 8.5 6.5 11.5 12.5 5"/>
                        </svg>
                      </span>
                    </label>
                  </li>
                {%- endfor -%}
              </ul>

              {%- assign t_add = 'products.product.add_to_cart' | t -%}
              <button type="button" class="cl-row-card__add" data-cl-add data-label-base="{{ t_add | escape }}" disabled>
                <span data-cl-add-label>{{ t_add }}</span>
              </button>
            {%- endif -%}
          </li>
        {%- endfor -%}

        {%- if cnt == 0 and host_product != blank -%}
          <li class="cl-row-empty">
            <p>No looks available for this product right now.</p>
          </li>
        {%- endif -%}
      </ul>
    </div>
  </div>
</section>

{% stylesheet %}
  .cl-row-section {
    --cl-bg: #F8F7F6;
    --cl-wine: #601119;
    --cl-wine-hover: #4d0e14;
    --cl-text: #2D2D2D;
    --cl-text-muted: #6B6868;
    --cl-chip-bg: #FCFBFB;
    --cl-chip-border: #E7E5E3;
    --cl-white: #FFFFFF;

    background: var(--cl-bg);
    color: var(--cl-text);
    padding: clamp(40px, 5vw, 64px) 0;
    font-family: 'Nimbus Sans Novus', var(--font-body-family, system-ui), -apple-system, sans-serif;
  }
  .cl-row-container { max-width: 1600px; margin: 0 auto; }

  .cl-row-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    padding: 0 clamp(20px, 5vw, 80px);
    margin-bottom: clamp(24px, 3vw, 36px);
  }
  .cl-row-head__text { max-width: 560px; }
  .cl-row-eyebrow {
    font-family: 'Nimbus Sans Novus Cond', 'Nimbus Sans Novus', sans-serif;
    font-weight: 700; font-size: 15px; line-height: 1;
    text-transform: uppercase; color: var(--cl-wine);
    letter-spacing: 0.02em; margin: 0 0 14px;
  }
  .cl-row-title {
    font-family: 'Nimbus Sans Novus Cond', 'Nimbus Sans Novus', sans-serif;
    font-weight: 700; font-size: clamp(28px, 3.5vw, 40px); line-height: 1;
    text-transform: uppercase; color: var(--cl-text); margin: 0 0 12px;
  }
  .cl-row-subtitle {
    font-weight: 500; font-size: 16px; line-height: 1.4;
    color: var(--cl-text); margin: 0; letter-spacing: 0.01em;
  }
  .cl-row-cta {
    display: inline-flex; align-items: center; height: 44px; padding: 0 22px;
    background: var(--cl-wine); color: var(--cl-white);
    font-family: 'Nimbus Sans Novus Cond', 'Nimbus Sans Novus', sans-serif;
    font-weight: 700; font-size: 14px; line-height: 1; text-transform: uppercase;
    letter-spacing: 0.04em; text-decoration: none; border-radius: 2px;
    flex-shrink: 0; transition: background 120ms ease;
  }
  .cl-row-cta:hover { background: var(--cl-wine-hover); color: var(--cl-white); }

  .cl-row-scroll {
    overflow-x: auto; overflow-y: visible;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; -ms-overflow-style: none;
    scroll-snap-type: x mandatory;
    scroll-padding-left: clamp(20px, 5vw, 80px);
    padding-bottom: 4px;
  }
  .cl-row-scroll::-webkit-scrollbar { display: none; }
  .cl-row-track {
    list-style: none; margin: 0;
    padding: 0 clamp(20px, 5vw, 80px);
    display: flex; gap: 16px;
  }

  .cl-row-card {
    flex: 0 0 290px; scroll-snap-align: start;
    display: flex; flex-direction: column; gap: 10px; min-width: 0;
  }
  @media (max-width: 749px) { .cl-row-card { flex-basis: 230px; } }
  .cl-row-card__image-wrap {
    aspect-ratio: 4 / 5; overflow: hidden;
    background: #efece9; border-radius: 2px;
  }
  .cl-row-card__image { width: 100%; height: 100%; object-fit: cover; display: block; }

  .cl-row-card__chips {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 4px;
    height: 156px; overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; -ms-overflow-style: none;
  }
  .cl-row-card__chips::-webkit-scrollbar { display: none; }
  .cl-row-card__chips > li { flex-shrink: 0; }

  .cl-row-section .cl-chip {
    position: relative; display: grid;
    grid-template-columns: 47px 1fr auto;
    align-items: center; gap: 12px;
    height: 61px; padding: 0 14px 0 0;
    background: var(--cl-chip-bg);
    border: 1px solid var(--cl-chip-border);
    border-radius: 2px; cursor: pointer;
    transition: border-color 120ms ease;
  }
  .cl-row-section .cl-chip:hover { border-color: #d0cdc9; }
  .cl-row-section .cl-chip__input { position: absolute; opacity: 0; pointer-events: none; }
  .cl-row-section .cl-chip__thumb {
    display: block; width: 47px; height: 59px;
    overflow: hidden; background: #efece9; text-decoration: none;
  }
  .cl-row-section .cl-chip__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cl-row-section .cl-chip__body {
    display: flex; flex-direction: column; gap: 2px; min-width: 0;
  }
  .cl-row-section .cl-chip__title {
    font-weight: 700; font-size: 13px; line-height: 1.4;
    color: var(--cl-text); letter-spacing: 0.01em;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .cl-row-section .cl-chip__price {
    font-weight: 500; font-size: 13px; line-height: 1.3;
    color: var(--cl-text); letter-spacing: 0.01em;
  }
  .cl-row-section .cl-chip__price-now { color: var(--cl-text); }
  .cl-row-section .cl-chip__price-was {
    text-decoration: line-through; color: var(--cl-text-muted); margin-left: 6px;
  }
  .cl-row-section .cl-chip__checkbox {
    display: inline-flex; align-items: center; justify-content: center;
    width: 20px; height: 20px;
    border: 1.5px solid var(--cl-chip-border);
    border-radius: 2px; background: var(--cl-white); color: var(--cl-white);
    transition: background 120ms ease, border-color 120ms ease; flex-shrink: 0;
  }
  .cl-row-section .cl-chip__checkbox svg { width: 12px; height: 12px; opacity: 0; transition: opacity 120ms ease; }
  .cl-row-section .cl-chip__input:checked ~ .cl-chip__checkbox {
    background: var(--cl-wine); border-color: var(--cl-wine);
  }
  .cl-row-section .cl-chip__input:checked ~ .cl-chip__checkbox svg { opacity: 1; }

  .cl-row-card__add {
    display: block; width: 100%; height: 40px; margin-top: 6px;
    background: var(--cl-wine); color: var(--cl-white);
    border: none; border-radius: 2px;
    font-family: 'Nimbus Sans Novus Cond', 'Nimbus Sans Novus', sans-serif;
    font-weight: 700; font-size: 16px; line-height: 1;
    text-transform: uppercase; letter-spacing: 0.04em;
    cursor: pointer; transition: background 120ms ease;
  }
  .cl-row-card__add:hover:not(:disabled) { background: var(--cl-wine-hover); }
  .cl-row-card__add:disabled { cursor: not-allowed; }
  .cl-row-card__add.is-loading { opacity: 0.7; cursor: wait; }
  .cl-row-card__add.is-success { background: #2d6a4f; }

  .cl-row-empty {
    padding: 24px; color: var(--cl-text-muted); font-size: 14px;
  }

  @media (max-width: 749px) {
    .cl-row-head { flex-direction: column; align-items: flex-start; }
    .cl-row-cta { align-self: stretch; justify-content: center; }
  }

  @media (hover: hover) and (pointer: fine) {
    .cl-row-scroll { cursor: grab; }
    .cl-row-scroll.is-dragging {
      cursor: grabbing; scroll-snap-type: none; user-select: none;
    }
  }
  .cl-row-card__image-wrap img { -webkit-user-drag: none; user-drag: none; }

  .cl-chip--sold-out {
    opacity: 0.6; cursor: not-allowed;
    background: #f4f3f1; position: relative;
  }
  .cl-chip--sold-out:hover { border-color: var(--cl-chip-border, #E7E5E3) !important; }
  .cl-chip--sold-out .cl-chip__title,
  .cl-chip--sold-out .cl-chip__price { color: #888; }
  .cl-chip--sold-out .cl-chip__price { text-decoration: line-through; }
  .cl-chip--sold-out::after {
    content: 'Udsolgt'; position: absolute;
    top: 8px; right: 38px;
    background: #c0392b; color: #fff;
    font-family: 'Nimbus Sans Novus Cond', 'Nimbus Sans Novus', sans-serif;
    font-size: 9px; font-weight: 700; line-height: 1;
    padding: 4px 7px; border-radius: 2px;
    text-transform: uppercase; letter-spacing: 0.04em;
    pointer-events: none;
  }
  .cl-chip--sold-out .cl-chip__checkbox { opacity: 0.25; pointer-events: none; }

{% endstylesheet %}

{% javascript %}
  (function () {
    const sections = document.querySelectorAll('[data-cl-row]');
    sections.forEach((section) => {
      const scroller = section.querySelector('.cl-row-scroll');
      if (scroller && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
        let pointerDown = false;
        let startX = 0; let startY = 0;
        let scrollStart = 0; let dragged = false;
        const DRAG_THRESHOLD = 5;

        scroller.addEventListener('mousedown', (e) => {
          if (e.button !== 0) return;
          pointerDown = true; dragged = false;
          startX = e.pageX; startY = e.pageY;
          scrollStart = scroller.scrollLeft;
        });
        scroller.addEventListener('mousemove', (e) => {
          if (!pointerDown) return;
          const dx = e.pageX - startX; const dy = e.pageY - startY;
          if (!dragged && Math.abs(dx) > DRAG_THRESHOLD && Math.abs(dx) > Math.abs(dy)) {
            dragged = true; scroller.classList.add('is-dragging');
          }
          if (dragged) { scroller.scrollLeft = scrollStart - dx; e.preventDefault(); }
        });
        const release = () => {
          if (!pointerDown) return;
          pointerDown = false;
          if (dragged) scroller.classList.remove('is-dragging');
        };
        scroller.addEventListener('mouseup', release);
        scroller.addEventListener('mouseleave', release);
        scroller.addEventListener('click', (e) => {
          if (dragged) { e.preventDefault(); e.stopPropagation(); dragged = false; }
        }, true);
        scroller.addEventListener('dragstart', (e) => e.preventDefault());
      }

      const cards = section.querySelectorAll('[data-cl-card]');
      cards.forEach((card) => {
        const inputs = card.querySelectorAll('.cl-chip__input');
        const button = card.querySelector('[data-cl-add]');
        const label = card.querySelector('[data-cl-add-label]');
        if (!button || !label) return;
        const baseLabel = button.dataset.labelBase || 'Add to cart';
        const updateLabel = () => {
          const checked = card.querySelectorAll('.cl-chip__input:checked');
          const n = checked.length;
          button.disabled = n === 0;
          label.textContent = n === 0 ? baseLabel : baseLabel + ' (' + n + ')';
        };
        inputs.forEach((input) => input.addEventListener('change', updateLabel));
        card.querySelectorAll('.cl-chip__thumb').forEach((a) => {
          a.addEventListener('click', (e) => {
            e.stopPropagation(); e.preventDefault();
            window.location.href = a.getAttribute('href');
          });
        });
        button.addEventListener('click', async (e) => {
          e.preventDefault();
          const checked = Array.from(card.querySelectorAll('.cl-chip__input:checked'));
          if (!checked.length) return;
          const items = checked.map((i) => ({ id: parseInt(i.dataset.variantId, 10), quantity: 1 }));
          const cart = document.querySelector('cart-notification') || document.querySelector('cart-drawer');
          const sections = (cart && typeof cart.getSectionsToRender === 'function')
            ? cart.getSectionsToRender().map((s) => s.id) : [];
          if (cart && typeof cart.setActiveElement === 'function') cart.setActiveElement(button);
          button.classList.add('is-loading'); button.disabled = true;
          try {
            const r = await fetch((window.routes && window.routes.cart_add_url) || '/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ items, sections, sections_url: window.location.pathname })
            });
            const response = await r.json();
            if (!r.ok || response.status) {
              throw new Error(response.description || ('add failed (' + r.status + ')'));
            }
            if (cart && typeof cart.renderContents === 'function') {
              const respItems = response.items || [response];
              const lastItem = respItems[respItems.length - 1] || {};
              cart.renderContents({
                key: lastItem.key, product_id: lastItem.product_id, sections: response.sections
              });
              if (respItems.length > 1) {
                const container = document.getElementById('cart-notification-product');
                if (container) {
                  const list = document.createElement('div');
                  list.className = 'cl-multi-add';
                  checked.forEach((input) => {
                    const chipEl = input.closest('.cl-chip');
                    if (!chipEl) return;
                    const thumb = chipEl.querySelector('.cl-chip__thumb img');
                    const titleEl = chipEl.querySelector('.cl-chip__title');
                    const priceEl = chipEl.querySelector('.cl-chip__price');
                    const item = document.createElement('div');
                    item.className = 'cl-multi-item';
                    if (thumb) {
                      const img = document.createElement('img');
                      img.src = thumb.currentSrc || thumb.src;
                      img.alt = thumb.alt || '';
                      img.width = 48; img.height = 48;
                      item.appendChild(img);
                    }
                    const body = document.createElement('div');
                    body.className = 'cl-multi-item__body';
                    const title = document.createElement('span');
                    title.className = 'cl-multi-item__title';
                    title.textContent = titleEl ? titleEl.textContent.trim() : '';
                    body.appendChild(title);
                    const price = document.createElement('span');
                    price.className = 'cl-multi-item__price';
                    if (priceEl) price.innerHTML = priceEl.innerHTML;
                    body.appendChild(price);
                    item.appendChild(body);
                    list.appendChild(item);
                  });
                  container.innerHTML = '';
                  container.appendChild(list);
                }
                if (!document.getElementById('cl-multi-add-styles')) {
                  const style = document.createElement('style');
                  style.id = 'cl-multi-add-styles';
                  style.textContent =
                    '.cl-multi-add{display:flex;flex-direction:column;gap:8px;padding:4px 0}' +
                    '.cl-multi-item{display:grid;grid-template-columns:48px 1fr;gap:12px;align-items:center;padding:8px 10px;background:rgba(0,0,0,.04);border-radius:4px}' +
                    '.cl-multi-item img{width:48px;height:48px;object-fit:cover;border-radius:2px;display:block}' +
                    '.cl-multi-item__body{display:flex;flex-direction:column;gap:2px;min-width:0}' +
                    '.cl-multi-item__title{font-size:13px;font-weight:600;line-height:1.3;color:#2D2D2D;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}' +
                    '.cl-multi-item__price{font-size:12px;line-height:1.2;color:#2D2D2D}' +
                    '.cl-multi-item__price .cl-chip__price-now{color:#2D2D2D;font-weight:600}' +
                    '.cl-multi-item__price .cl-chip__price-was{text-decoration:line-through;color:#6B6868;margin-left:4px;font-weight:400}';
                  document.head.appendChild(style);
                }
              }
            }
            button.classList.remove('is-loading');
            button.classList.add('is-success');
            label.textContent = '✓';
            setTimeout(() => {
              button.classList.remove('is-success');
              checked.forEach((i) => { i.checked = false; });
              updateLabel();
            }, 1800);
          } catch (err) {
            button.classList.remove('is-loading');
            button.disabled = false;
            const msg = (err && err.message) ? String(err.message) : '';
            let displayMsg = 'Prøv igen';
            if (/udsolgt|sold[- ]?out|unavailable/i.test(msg)) displayMsg = 'Udsolgt — fjern og prøv igen';
            else if (/422|400/.test(msg)) displayMsg = 'Kunne ikke tilføjes';
            label.textContent = displayMsg;
            setTimeout(() => { if (label.textContent === displayMsg) updateLabel(); }, 4000);
            console.error('[customer-looks-row] add to cart failed', err);
          }
        });
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Customer Looks Row",
  "tag": "section",
  "class": "section-customer-looks-row",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GET INSPIRED" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "THE LOOKS" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Fra hjemmebrug til perfektion. Se hvordan TGC-fællesskabet bruger dette produkt i deres gel-rutine." },
    { "type": "range", "id": "count", "label": "Number of photos", "min": 4, "max": 30, "step": 1, "default": 12 },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Se alle looks" },
    { "type": "url", "id": "cta_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Customer Looks Row" }
  ]
}
{% endschema %}
